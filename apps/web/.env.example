# Portal DLH — web app environment (NON-SECRET).
# These are public URLs baked into the client bundle at build time. There are no
# secrets in this app. Copy to .env.local for local overrides (optional — the
# defaults below already point at the live apps).

# Local dev server port (defaults to 3000).
# WEB_PORT=3000

# Public URLs of the apps the portal links out to.
NEXT_PUBLIC_SEKAR_URL=https://sekar.wahyutrip.com
NEXT_PUBLIC_SWAT_URL=https://swat.wahyutrip.com
