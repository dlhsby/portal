# syntax=docker/dockerfile:1.7
# Multi-stage production image for the DLH portal Next.js landing page.
# Build context = repo root (the portal monorepo):
#   docker build -f infra/Dockerfile.web -t portal-web .
#
# This is a purely static landing page — NO secrets, NO dotenvx. The only build
# inputs are the two public app URLs (NEXT_PUBLIC_*), passed as build args and
# inlined into the client bundle at `next build`. They default to the live apps
# so a bare `docker build` still produces a correct image.

# --- deps -------------------------------------------------------------------
# Install the FULL workspace so pnpm's isolated per-package node_modules (e.g.
# apps/web/node_modules/.bin/next) exist — pnpm doesn't hoist.
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS deps
RUN corepack enable
WORKDIR /app
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc turbo.json ./
COPY apps/web/package.json apps/web/
COPY packages/tsconfig/package.json packages/tsconfig/
COPY packages/eslint-config/package.json packages/eslint-config/
RUN pnpm install --frozen-lockfile

# --- build ------------------------------------------------------------------
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS build
RUN corepack enable
WORKDIR /app
# Complete installed tree (root + per-package node_modules), then overlay source.
COPY --from=deps /app ./
COPY . .

# Public app URLs — inlined into the bundle at build time. CI passes the real
# domains; the defaults already point at the live apps.
ARG NEXT_PUBLIC_SEKAR_URL=https://sekar.wahyutrip.com
ARG NEXT_PUBLIC_SWAT_URL=https://swat.wahyutrip.com
ENV NEXT_PUBLIC_SEKAR_URL=$NEXT_PUBLIC_SEKAR_URL
ENV NEXT_PUBLIC_SWAT_URL=$NEXT_PUBLIC_SWAT_URL
ENV NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter @portal/web build

# --- runtime ----------------------------------------------------------------
# Next standalone output (next.config.mjs `output: 'standalone'`): a self-contained
# server with only its traced deps — no full node_modules, no pnpm at runtime.
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS runtime
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /app
# The standalone bundle (traced node_modules + server.js, monorepo-rooted). chown to
# the non-root `node` user so any runtime cache writes under .next succeed.
COPY --from=build --chown=node:node /app/apps/web/.next/standalone ./
# Static assets + public dir are not traced into standalone; copy them alongside.
COPY --from=build --chown=node:node /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=node:node /app/apps/web/public ./apps/web/public
USER node
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
